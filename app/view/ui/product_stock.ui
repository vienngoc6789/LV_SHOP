  <property name="styleSheet">
   <string><![CDATA[
QWidget#ProductStockPage {
    background-color: #f8fafc;
}

QFrame#formPanel,
QFrame#tablePanel,
QFrame#imeiPanel,
QFrame#warningPanel {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 16px;
}

QLabel.formLabel {
    color: #334155;
    font-size: 12px;
    font-weight: bold;
}

QLineEdit,
QComboBox,
QDoubleSpinBox,
QTextEdit {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 6px 10px;
    color: #0f172a;
    font-size: 13px;
}

QLineEdit:focus,
QComboBox:focus,
QDoubleSpinBox:focus,
QTextEdit:focus {
    border: 2px solid #2563eb;
    background-color: white;
}

QComboBox {
    border-radius: 12px;
    min-height: 34px;
}

QComboBox::drop-down {
    border: none;
    width: 28px;
    border-top-right-radius: 12px;
    border-bottom-right-radius: 12px;
}

QComboBox QAbstractItemView {
    background-color: white;
    color: #0f172a;
    selection-background-color: #dbeafe;
    selection-color: #0f172a;
    border: 1px solid #93c5fd;
    border-radius: 10px;
    padding: 6px;
    font-size: 13px;
}

QPushButton {
    border: none;
    border-radius: 11px;
    padding: 7px;
    font-size: 13px;
    font-weight: bold;
    min-height: 24px;
}

QPushButton#btnAdd {
    background-color: #2563eb;
    color: white;
}

QPushButton#btnUpdate {
    background-color: #16a34a;
    color: white;
}

QPushButton#btnDelete,
QPushButton#btnDeleteImei {
    background-color: #dc2626;
    color: white;
}

QPushButton#btnShowVariants {
    background-color: #dbeafe;
    color: #1e3a8a;
    border: 1px solid #bfdbfe;
    border-radius: 14px;
}

QPushButton#btnMarkImeiSold {
    background-color: #f59e0b;
    color: white;
}

QPushButton#btnRefresh {
    background-color: #0f172a;
    color: white;
}

QPushButton#btnClear {
    background-color: #e2e8f0;
    color: #0f172a;
}

QTableWidget {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    gridline-color: #e2e8f0;
    color: #0f172a;
    font-size: 12px;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #dbeafe;
    color: #0f172a;
}

QHeaderView::section {
    background-color: #1e3a8a;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QListWidget {
    background-color: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 10px;
    padding: 5px;
    color: #dc2626;
    font-size: 12px;
}
   ]]></string>
