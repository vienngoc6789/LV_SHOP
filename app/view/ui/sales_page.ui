  <property name="styleSheet">
   <string><![CDATA[
QWidget#SalesPage {
    background-color: #f8fafc;
}

QFrame#customerPanel,
QFrame#productPanel,
QFrame#cartPanel,
QFrame#paymentPanel,
QFrame#summaryBox {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 16px;
}

QFrame#totalBox {
    background-color: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 16px;
}

QLabel.sectionTitle {
    color: #1e3a8a;
    font-size: 16px;
    font-weight: bold;
}

QLabel.formLabel {
    color: #334155;
    font-size: 12px;
    font-weight: bold;
}

QLineEdit,
QComboBox,
QDoubleSpinBox,
QSpinBox,
QTextEdit {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 6px 10px;
    color: #0f172a;
    font-size: 13px;
}

QLineEdit:focus,
QComboBox:focus,
QDoubleSpinBox:focus,
QSpinBox:focus,
QTextEdit:focus {
    border: 2px solid #2563eb;
    background-color: white;
}

QPushButton {
    border: none;
    border-radius: 11px;
    padding: 7px;
    font-size: 13px;
    font-weight: bold;
    min-height: 24px;
}

QPushButton#btnFindCustomer,
QPushButton#btnImportCustomer,
QPushButton#btnFindImei,
QPushButton#btnAddToCart,
QPushButton#btnExportInvoice {
    background-color: #2563eb;
    color: white;
}

QPushButton#btnNewCustomer,
QPushButton#btnClearCart {
    background-color: #e2e8f0;
    color: #0f172a;
}

QPushButton#btnRemoveCartItem {
    background-color: #dc2626;
    color: white;
}

QPushButton#btnConfirmPayment {
    background-color: #16a34a;
    color: white;
    font-size: 15px;
}

QPushButton#btnApplyDiscount,
QPushButton#btnShowQr {
    background-color: #7c3aed;
    color: white;
}

QTableWidget {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    gridline-color: #e2e8f0;
    color: #0f172a;
    font-size: 12px;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #dbeafe;
    color: #0f172a;
}

QHeaderView::section {
    background-color: #1e3a8a;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QRadioButton {
    color: #334155;
    font-size: 13px;
    font-weight: bold;
}

QLabel#lblTotalValue {
    color: #dc2626;
    font-size: 30px;
    font-weight: bold;
}

QLabel#lblSubtotalValue,
QLabel#lblDiscountValue,
QLabel#lblChangeValue {
    font-size: 15px;
    font-weight: bold;
}

QLabel#lblSubtotalValue {
    color: #0f172a;
}

QLabel#lblDiscountValue {
    color: #7c3aed;
}

QLabel#lblChangeValue {
    color: #16a34a;
}

QLabel#lblQrImage {
    background-color: transparent;
}
   ]]></string>
