  <property name="styleSheet">
   <string><![CDATA[
QWidget#CustomerPage {
    background-color: #f8fafc;
}

QFrame#formPanel,
QFrame#listPanel,
QFrame#detailPanel,
QFrame#historyPanel,
QFrame#summaryCard1,
QFrame#summaryCard2,
QFrame#summaryCard3 {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 16px;
}

QLabel.sectionTitle {
    color: #1e3a8a;
    font-size: 16px;
    font-weight: bold;
}

QLabel.formLabel {
    color: #334155;
    font-size: 12px;
    font-weight: bold;
}
QComboBox {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 6px 32px 6px 10px;
    color: #0f172a;
    font-size: 13px;
    min-height: 28px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border-left: 1px solid #cbd5e1;
    border-top-right-radius: 12px;
    border-bottom-right-radius: 12px;
    background-color: #eff6ff;
}

QComboBox::down-arrow {
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background-color: white;
    color: #0f172a;
    selection-background-color: #dbeafe;
    selection-color: #0f172a;
    border: 1px solid #93c5fd;
    border-radius: 10px;
    padding: 6px;
    outline: 0;
    font-size: 13px;
}
QLabel.statNumber {
    color: #2563eb;
    font-size: 22px;
    font-weight: bold;
}

QLabel.statText {
    color: #64748b;
    font-size: 12px;
}

QLineEdit,
QComboBox,
QTextEdit {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 6px 10px;
    color: #0f172a;
    font-size: 13px;
}

QLineEdit:focus,
QComboBox:focus,
QTextEdit:focus {
    border: 2px solid #2563eb;
    background-color: white;
}

QPushButton {
    border: none;
    border-radius: 11px;
    padding: 7px;
    font-size: 13px;
    font-weight: bold;
    min-height: 24px;
}

QPushButton#btnAddCustomer,
QPushButton#btnUpdateCustomer,
QPushButton#btnSearchCustomer,
QPushButton#btnViewInvoice,
QPushButton#btnViewWarranty {
    background-color: #2563eb;
    color: white;
}

QPushButton#btnUpdateCustomer {
    background-color: #16a34a;
}

QPushButton#btnDeleteCustomer {
    background-color: #dc2626;
    color: white;
}

QPushButton#btnClearForm,
QPushButton#btnRefresh,
QPushButton#btnExportCustomer {
    background-color: #e2e8f0;
    color: #0f172a;
}

QPushButton#btnVipCustomer {
    background-color: #7c3aed;
    color: white;
}

QTableWidget {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    gridline-color: #e2e8f0;
    color: #0f172a;
    font-size: 12px;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #dbeafe;
    color: #0f172a;
}

QHeaderView::section {
    background-color: #1e3a8a;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}
   ]]></string>
