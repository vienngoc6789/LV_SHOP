    font-size: 12px;
}

#lblChartTitle, #lblQuickActionTitle, #lblRecentActivityTitle, #lblWarningTitle {
    color: #1e3a8a;
    font-size: 18px;
    font-weight: bold;
}

#chartFrame {
    background-color: #f8fafc;
    border: 1px dashed #93c5fd;
    border-radius: 14px;
}

#lblChartPlaceholder {
    color: #64748b;
    font-size: 15px;
}

#btnCreateOrder, #btnAddProduct, #btnAddCustomer {
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 12px;
    font-size: 14px;
    font-weight: bold;
}

#btnCreateOrder:hover, #btnAddProduct:hover, #btnAddCustomer:hover {
    background-color: #1d4ed8;
}

#btnCreateOrder:pressed, #btnAddProduct:pressed, #btnAddCustomer:pressed {
    background-color: #1e40af;
}

QListWidget {
    background-color: #f8fafc;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    padding: 8px;
    color: #334155;
    font-size: 13px;
}

QListWidget::item {
    padding: 8px;
    border-radius: 8px;
}

QListWidget::item:hover {
    background-color: #dbeafe;
}
