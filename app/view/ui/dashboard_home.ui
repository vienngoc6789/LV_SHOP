}

#lblRevenueIcon, #lblOrderIcon, #lblProductIcon, #lblCustomerIcon {
    font-size: 30px;
}

#lblRevenueTitle, #lblOrderTitle, #lblProductTitle, #lblCustomerTitle {
    color: #64748b;
    font-size: 13px;
    font-weight: bold;
}

