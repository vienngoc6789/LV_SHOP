    border: 1px solid #dbeafe;
    border-radius: 18px;
}

#cardRevenueToday:hover, #cardOrderToday:hover, #cardProductCount:hover, #cardCustomerCount:hover,
#chartPanel:hover, #quickActionPanel:hover, #recentActivityPanel:hover, #warningPanel:hover {
