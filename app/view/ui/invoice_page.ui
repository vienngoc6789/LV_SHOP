  <property name="styleSheet">
   <string><![CDATA[
QWidget#InvoicePage {
    background-color: #f8fafc;
}

QFrame#filterPanel,
QFrame#invoicePanel,
QFrame#detailPanel,
QFrame#summaryCard1,
QFrame#summaryCard2,
QFrame#summaryCard3,
QFrame#summaryCard4,
QFrame#detailInfoBox,
QFrame#moneyBox {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 16px;
}

QFrame#detailInfoBox,
QFrame#moneyBox {
    background-color: #f8fbff;
}

QLabel.sectionTitle {
    color: #1e3a8a;
    font-size: 16px;
    font-weight: bold;
}

QLabel.formLabel {
    color: #334155;
    font-size: 12px;
    font-weight: bold;
}

QLabel.valueLabel {
    color: #0f172a;
    font-size: 13px;
    font-weight: bold;
}

QLabel.statNumber {
    color: #2563eb;
    font-size: 21px;
    font-weight: bold;
}

QLabel.statText {
    color: #64748b;
    font-size: 12px;
}

QLineEdit,
QDateEdit,
QComboBox {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 6px 32px 6px 10px;
    color: #0f172a;
    font-size: 13px;
    min-height: 28px;
}

QLineEdit:focus,
QDateEdit:focus,
QComboBox:focus {
    border: 2px solid #2563eb;
    background-color: white;
}

QComboBox::drop-down,
QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border-left: 1px solid #cbd5e1;
    border-top-right-radius: 12px;
    border-bottom-right-radius: 12px;
    background-color: #eff6ff;
}

QComboBox QAbstractItemView {
    background-color: white;
    color: #0f172a;
    selection-background-color: #dbeafe;
    selection-color: #0f172a;
    border: 1px solid #93c5fd;
    border-radius: 10px;
    padding: 6px;
    outline: 0;
    font-size: 13px;
}

QPushButton {
    border: none;
    border-radius: 11px;
    padding: 7px 10px;
    font-size: 13px;
    font-weight: bold;
    min-height: 24px;
}

QPushButton#btnSearch,
QPushButton#btnViewDetail,
QPushButton#btnExportPdf,
QPushButton#btnReprintInvoice {
    background-color: #2563eb;
    color: white;
}

QPushButton#btnRefresh,
QPushButton#btnClearFilter {
    background-color: #e2e8f0;
    color: #0f172a;
}

QPushButton#btnCancelInvoice {
    background-color: #dc2626;
    color: white;
}

QPushButton#btnReturnItem {
    background-color: #f59e0b;
    color: white;
}

QTableWidget {
    background-color: white;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    gridline-color: #e2e8f0;
    color: #0f172a;
    font-size: 12px;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #dbeafe;
    color: #0f172a;
}

QHeaderView::section {
    background-color: #1e3a8a;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}
   ]]></string>
