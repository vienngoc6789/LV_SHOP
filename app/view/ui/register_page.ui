  <property name="styleSheet">
   <string notr="true">
QWidget#RegisterPage {
    background-color: #eff6ff;
}

QFrame#registerCard {
    background-color: #ffffff;
    border-radius: 24px;
    border: 1px solid #dbeafe;
}

QLabel#lblTitle {
    color: #1e3a8a;
    font-size: 30px;
    font-weight: bold;
}

QLabel#lblSubtitle {
    color: #64748b;
    font-size: 14px;
}

QLabel.formLabel {
    color: #334155;
    font-size: 13px;
    font-weight: bold;
}

QLineEdit, QDateEdit, QComboBox {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 10px 10px 10px 38px;
    font-size: 14px;
    color: #0f172a;
}

QLineEdit:focus, QDateEdit:focus, QComboBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

QLineEdit#txtFullName {
    background-image: url(E:\LV SHOP _PY\assets\icon\user.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QLineEdit#txtAddress {
    background-image: url(E:\LV SHOP _PY\assets\icon\location.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QLineEdit#txtPhone {
    background-image: url(icons/phone.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QLineEdit#txtEmail {
    background-image: url(icons/mail.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QLineEdit#txtUsername {
    background-image: url(icons/account.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QLineEdit#txtPassword,
QLineEdit#txtConfirmPassword {
    background-image: url(icons/lock.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QDateEdit#dateBirth {
    background-image: url(icons/calendar.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QComboBox#cboRole {
    background-image: url(icons/role.png);
    background-position: left 12px center;
    background-repeat: no-repeat;
}

QRadioButton {
    color: #334155;
    font-size: 14px;
    padding: 6px;
}

QPushButton#btnRegister {
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 14px;
    padding: 13px;
    font-size: 15px;
    font-weight: bold;
}

QPushButton#btnRegister:hover {
    background-color: #1d4ed8;
}

QPushButton#btnRegister:pressed {
    background-color: #1e40af;
}

QPushButton#btnBackLogin {
    background-color: transparent;
    color: #2563eb;
    border: none;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#btnShowPassword,
QPushButton#btnShowConfirmPassword {
    background-color: #eff6ff;
    color: #2563eb;
    border: 1px solid #bfdbfe;
    border-radius: 12px;
    font-size: 16px;
}

QPushButton#btnShowPassword:hover,
QPushButton#btnShowConfirmPassword:hover {
    background-color: #dbeafe;
}
   </string>
